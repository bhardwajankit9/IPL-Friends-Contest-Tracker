rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isDataOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasSharedAccess(userId) {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/users/$(userId)/shared_users/$(request.auth.uid));
    }

    function isValidPlayer(data) {
      return data.keys().hasAll(['id', 'name']) &&
             data.id is number &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100;
    }

    function isValidPrediction(pred) {
      return pred is map &&
             pred.keys().hasAll(['playerId', 'predictedWinner']) &&
             pred.playerId is number &&
             pred.predictedWinner is string && pred.predictedWinner.size() < 100;
    }

    function areValidPredictions(preds) {
      return preds is list && preds.size() < 100;
    }

    function isValidMatch(data) {
      return data.keys().hasAll(['id', 'name', 'type', 'entryFee', 'totalPool', 'predictions', 'actualWinner', 'prizeWinner', 'prizeRunnerUp', 'timestamp']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.type in ['Normal', 'Qualifier', 'Final', 'Custom', 'Tie'] &&
             data.entryFee is number && data.entryFee >= 0 &&
             data.totalPool is number && data.totalPool >= 0 &&
             areValidPredictions(data.predictions) &&
             data.actualWinner is string && data.actualWinner.size() < 100 &&
             (!('winnerId' in data) || data.winnerId == null || data.winnerId is number) &&
             (!('runnerUpId' in data) || data.runnerUpId == null || data.runnerUpId is number) &&
             data.prizeWinner is number && data.prizeWinner >= 0 &&
             data.prizeRunnerUp is number && data.prizeRunnerUp >= 0 &&
             data.timestamp is number;
    }

    function isValidSharedUser(data) {
      return data.keys().hasAll(['id', 'email', 'displayName', 'grantedAt', 'grantedBy']) &&
             data.id is string && data.id.size() > 0 &&
             data.email is string && data.email.size() > 0 &&
             data.displayName is string &&
             data.grantedAt is number &&
             data.grantedBy is string && data.grantedBy == request.auth.uid;
    }

    // User documents (for shared access checking)
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isDataOwner(userId);
    }

    // Shared users collection
    match /users/{userId}/shared_users/{sharedUserId} {
      allow read, write: if isDataOwner(userId);
      allow read: if isAuthenticated() && request.auth.uid == sharedUserId;
    }

    // Seasons and their subcollections
    match /users/{userId}/seasons/{seasonId}/{document=**} {
      allow read, write: if isDataOwner(userId) || hasSharedAccess(userId);
    }
  }
}
